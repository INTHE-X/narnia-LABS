Options -Indexes
RewriteEngine On

# 실제 파일이 존재하면 그대로 서빙
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# admin/uploads/ → admin/public/uploads/ 직접 서빙 (Laravel 우회)
RewriteRule ^admin/uploads/(.*)$ admin/public/uploads/$1 [L]

# /admin/* 경로는 admin/public/index.php 로 전달 (Laravel)
RewriteCond %{REQUEST_URI} ^/admin
RewriteRule ^ admin/public/index.php [QSA,L]
